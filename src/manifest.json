{
  "manifest_version": 3,
  "name": "YouTube Article Generator",
  "version": "1.0.0",
  "description": "YouTube動画を技術記事・レシピ記事に変換してGitHubに保存",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://youtube.com/*",
    "https://api.github.com/*",
    "https://api.ai.sakura.ad.jp/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.openai.com/*",
    "https://api.anthropic.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content/youtube-inject.js"],
      "css": ["styles/content.css", "styles/modal.css"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options/options.html"
}
